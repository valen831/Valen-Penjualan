<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:background="?attr/toolbarBackground">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Kembali"
                android:src="@drawable/back"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/tvTitleHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Form Cabang"
                android:textSize="16sp"
                android:textColor="?attr/customTextColorPrimary" />

        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitlePage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tambah Cabang"
            android:textSize="24sp"
            android:textColor="?attr/customTextColorPrimary"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="24dp" />

        <!-- Label Nama Cabang -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Cabang"
            android:textSize="12sp"
            android:textColor="@color/purple"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etNamaCabang"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Masukkan nama cabang"
            android:textColorHint="?attr/customTextColorSecondary"
            android:textColor="?attr/customTextColorPrimary"
            android:textSize="16sp"
            android:padding="16dp"
            android:inputType="textCapWords"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="16dp" />

        <!-- Label Alamat Cabang -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alamat Cabang"
            android:textSize="12sp"
            android:textColor="@color/purple"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etAlamatCabang"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Masukkan alamat lengkap cabang"
            android:textColorHint="?attr/customTextColorSecondary"
            android:textColor="?attr/customTextColorPrimary"
            android:textSize="16sp"
            android:padding="16dp"
            android:inputType="textCapSentences"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="16dp" />

        <!-- Label Telepon Cabang -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No. Telepon Cabang"
            android:textSize="12sp"
            android:textColor="@color/purple"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etTeleponCabang"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Masukkan nomor telepon cabang"
            android:textColorHint="?attr/customTextColorSecondary"
            android:textColor="?attr/customTextColorPrimary"
            android:textSize="16sp"
            android:padding="16dp"
            android:inputType="phone"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="16dp" />

        <!-- Label Status Cabang -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status Keaktifan Cabang"
            android:textSize="12sp"
            android:textColor="?attr/customTextColorSecondary"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerStatus"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:padding="16dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="32dp" />

        <!-- Container Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp">

            <!-- Button Simpan -->
            <Button
                android:id="@+id/btnSimpan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Simpan Data"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#9C27B0"
                android:textStyle="bold" />

            <!-- Button Hapus (Muncul saat Mode Edit) -->
            <Button
                android:id="@+id/btnHapus"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="Hapus Cabang"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#F44336"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>

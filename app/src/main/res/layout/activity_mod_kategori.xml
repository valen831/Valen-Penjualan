<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/backgroundColor">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="?attr/toolbarBackground">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="Back"
            android:src="@drawable/back"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Tambah Kategori"
            android:textSize="16sp"
            android:textColor="?attr/customTextColorPrimary" />

    </LinearLayout>

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tambah Kategori"
        android:textSize="24sp"
        android:textColor="?attr/customTextColorPrimary"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="24dp" />

    <!-- Label Nama Kategori -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama Kategori"
        android:textSize="12sp"
        android:textColor="@color/purple"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etNamaKategori"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Masukkan nama kategori"
        android:textColorHint="?attr/customTextColorSecondary"
        android:textColor="?attr/customTextColorPrimary"
        android:textSize="16sp"
        android:padding="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp" />

    <!-- Label Status Kategori -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status Kategori"
        android:textSize="12sp"
        android:textColor="?attr/customTextColorSecondary"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinnerJenis"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:padding="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnSimpan"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Simpan"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#9C27B0"
        android:textStyle="bold"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp" />

</LinearLayout>